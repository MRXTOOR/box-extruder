FROM golang:1.25-alpine AS builder
WORKDIR /app
ENV GOTOOLCHAIN=auto
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /dast-worker ./cmd/worker

FROM alpine:3.19
RUN apk add --no-cache ca-certificates curl docker-cli
COPY --from=builder /dast-worker /usr/local/bin/
CMD ["dast-worker"]