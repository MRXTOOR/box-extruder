# Copy to .env: docker compose run --rm ci-runner
DAST_API_URL=http://host.docker.internal:8080
# Platform auth: CI token (preferred) OR login/password
# DAST_CI_TOKEN=dast_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DAST_USER=admin
DAST_PASS=admin123
DAST_TARGET=https://example.com
DAST_INSECURE_SKIP_VERIFY=true
DAST_FAIL_ON=HIGH
DAST_TIMEOUT_MINUTES=5

# Optional: authenticated scan (auth URL auto-detected when omitted)
# APP_USER=user@example.com
# APP_PASS=secret
# DAST_AUTH_URL=https://app.example.com/api/v1/auth/login
