// Alternative: entire DAST stage runs on an agent inside the ci-runner container.
// No runnerImage parameter needed — the step uses curl inside the same container.
//
@Library('dast') _

pipeline {
    agent none

    stages {
        stage('DAST scan') {
            agent {
                docker {
                    image 'appsec-dast/ci-runner:latest'
                    reuseNode true
                    args '-u 0:0 -v $WORKSPACE:/work -w /work'
                }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'dast-api', usernameVariable: 'DAST_USER', passwordVariable: 'DAST_PASS')]) {
                    sh '''
                        export DAST_WORK_DIR=/work
                        export DAST_API_URL=http://dast-server:8080
                        export DAST_TARGET=https://staging.myapp.example.com
                        export DAST_INSECURE_SKIP_VERIFY=true
                        export DAST_FAIL_ON=HIGH
                        /opt/dast/dast-scan.sh
                    '''
                }
                archiveArtifacts artifacts: 'dast-*', allowEmptyArchive: true
            }
        }
    }
}
